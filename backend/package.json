{
  "name": "@ppwl/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "dev:prod": "NODE_ENV=production bun --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "build:lambda": "bun build src/lambda.ts --outdir dist --target node --format cjs --minify",
    "start": "NODE_ENV=production bun dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "bun prisma/seed.ts",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@elysiajs/cors": "latest",
    "@elysiajs/jwt": "latest",
    "@elysiajs/swagger": "^1.3.1",
    "@prisma/client": "^6",
    "@react-oauth/google": "^0.13.5",
    "@scalar/themes": "^0.15.5",
    "@scalar/types": "^0.12.2",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "elysia": "latest",
    "nanoid": "^5.1.11",
    "pusher": "^5.3.3",
    "sanitize-html": "^2.17.4",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@types/sanitize-html": "^2.16.1",
    "@types/web-push": "^3.6.4",
    "prisma": "^6",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  }
}

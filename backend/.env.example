# URL ke database PostgreSQL lokal Anda
DATABASE_URL="postgresql://USERNAME_POSTGRES:PASSWORD_POSTGRES@localhost:5432/ppwl_ig"


# Rahasia untuk Login JWT nanti
JWT_SECRET="bebas_isi_dengan_teks_rahasia_apa_saja"

# Port Frontend & Backend
VITE_API_BASE_URL="http://localhost:3000"
PORT=3000

# URL Frontend (untuk CORS)
FRONTEND_URL="http://localhost:5173"

# Cloudinary — Daftar gratis di https://cloudinary.com
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Pusher — opsional, kosongkan untuk mode local tanpa realtime websocket
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="ap1"

# Web Push — generate dengan: bunx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=""
WEB_PUSH_PRIVATE_KEY=""
WEB_PUSH_SUBJECT="mailto:admin@instafy.local"

# API Secret Key — untuk akses endpoint admin/monitoring (untuk dosen/grading)
# Generate dengan: openssl rand -base64 32
# WAJIB diisi dengan key yang kuat (minimal 32 karakter) di production
API_SECRET_KEY=""

# URL ke database PostgreSQL lokal Anda
DATABASE_URL="postgresql://USERNAME_POSTGRES:PASSWORD_POSTGRES@localhost:5432/ppwl_ig"

# Dual Database Production (Opsional untuk Active-Active Failover)
DATABASE_URL_SUPABASE="postgresql://your_supabase_connection_string"
DATABASE_URL_NEON="postgresql://your_neon_connection_string"

# Rahasia untuk Login JWT nanti
JWT_SECRET="bebas_isi_dengan_teks_rahasia_apa_saja"

# Port Frontend & Backend
VITE_API_BASE_URL="http://localhost:3000"
PORT=3000

# URL Frontend (untuk CORS)
FRONTEND_URL="http://localhost:5173"

# Cloudinary — Daftar gratis di https://cloudinary.com
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
